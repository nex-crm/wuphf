{
  "name": "@wuphf/agent-runners",
  "version": "0.0.0",
  "private": true,
  "description": "WUPHF v1 agent runners — lifecycle, event streams, and Claude CLI adapter.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "check": "biome check src/ tests/"
  },
  "dependencies": {
    "@wuphf/protocol": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "2.1.9",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
