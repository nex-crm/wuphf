{
  "name": "@wuphf/broker",
  "version": "0.0.0",
  "private": true,
  "description": "WUPHF v1 broker — loopback HTTP+SSE+WebSocket listener with DNS-rebinding guard, bearer-token auth, and the /api-token bootstrap. Pure Node; no Electron, no business logic. Branch-4 slice of the rewrite.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./agent-provider-routing": "./src/agent-provider-routing/index.ts",
    "./approvals": "./src/approvals/index.ts",
    "./cost-ledger": "./src/cost-ledger/index.ts",
    "./event-log": "./src/event-log/index.ts",
    "./sqlite": "./src/sqlite-receipt-store.ts",
    "./threads": "./src/threads/index.ts",
    "./webauthn": "./src/webauthn/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci:thread-replay-check": "vitest run tests/threads/thread-state.spec.ts tests/threads/thread-routes.spec.ts --testNamePattern replay-check",
    "ci:thread-invariants": "vitest run tests/threads/effective-status.spec.ts tests/threads/thread-state.spec.ts tests/threads/thread-routes.spec.ts tests/threads/thread-routes-unit.spec.ts",
    "ci:thread-stress": "tsx scripts/thread-stress-profile.ts",
    "lint": "biome check src/ tests/ scripts/",
    "lint:fix": "biome check --write src/ tests/ scripts/",
    "format": "biome format --write src/ tests/ scripts/",
    "check": "biome check src/ tests/ scripts/",
    "check:invariants": "bash scripts/check-invariants.sh"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.0.0",
    "@wuphf/agent-runners": "workspace:*",
    "@wuphf/credentials": "workspace:*",
    "@wuphf/protocol": "workspace:*",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.9.1",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.7",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
