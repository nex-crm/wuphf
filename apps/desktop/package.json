{
  "name": "@wuphf/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "WUPHF v1 desktop shell — Electron main + preload + minimal renderer. Sandboxed renderer, contextBridge typed allowlist (OS verbs only), utilityProcess.fork() broker spawning. No app-data IPC; the renderer reaches the broker over loopback HTTP/SSE in a later branch.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.preload.json && tsc --noEmit -p tsconfig.renderer.json",
    "lint": "biome check src/ tests/ scripts/",
    "lint:fix": "biome check --write src/ tests/ scripts/",
    "format": "biome format --write src/ tests/ scripts/",
    "check": "biome check src/ tests/ scripts/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:install": "bun scripts/install-electron.mjs",
    "build": "electron-vite build",
    "dev": "bun run electron:install && electron-vite dev",
    "preview": "bun run electron:install && electron-vite preview",
    "check:ipc-allowlist": "bash scripts/check-ipc-allowlist.sh",
    "check:invariants": "bash scripts/check-invariants.sh"
  },
  "dependencies": {
    "@wuphf/protocol": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "24.12.3",
    "@vitest/coverage-v8": "4.1.5",
    "electron": "42.0.1",
    "electron-vite": "5.0.0",
    "typescript": "5.9.3",
    "vite": "7.3.3",
    "vitest": "4.1.5"
  }
}
