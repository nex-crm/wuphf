{
  "name": "wuphf-dev-tooling",
  "private": true,
  "description": "Root-level dev tooling (secretlint, commitlint). The Go v0 app lives at the repo root; web UI lives in ./web with its own package.json; v1 protocol package lives in ./packages/protocol; v1 desktop shell lives in ./apps/desktop.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "fast-uri": "3.1.2"
  },
  "scripts": {
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:build": "bun run --cwd apps/desktop build",
    "desktop:test": "bun run --cwd apps/desktop test",
    "desktop:typecheck": "bun run --cwd apps/desktop typecheck",
    "desktop:check:ipc-allowlist": "bun run --cwd apps/desktop check:ipc-allowlist",
    "desktop:check:invariants": "bun run --cwd apps/desktop check:invariants"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@secretlint/secretlint-rule-pattern": "13.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.0",
    "secretlint": "13.0.0"
  },
  "version": "0.0.0"
}
