{
  "name": "@nex-ai/cli",
  "version": "0.1.0",
  "description": "Nex CLI — full-parity command-line interface for the Nex Developer API",
  "type": "module",
  "bin": {
    "nex": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
