# Ignore Wails build output (binaries, .app/.dmg/.exe) and generated scaffolding,
# but TRACK the signing config (bundle id + entitlements) so CI signs correctly.
/build/*
!/build/darwin/
/build/darwin/*
!/build/darwin/Info.plist
!/build/darwin/entitlements.plist

# Wails-generated JS runtime bindings (regenerated by `wails build`; we build
# with -skipbindings and the UI comes from the in-process broker anyway).
/frontend/wailsjs/
